APP_NAME="CRM"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_TIMEZONE=UTC
APP_LOCALE=ru

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=8889
DB_DATABASE=crm
DB_USERNAME=root
DB_PASSWORD=root
# MAMP: если по порту не подключается, раскомментируйте следующую строку:
# DB_SOCKET=/Applications/MAMP/tmp/mysql/mysql.sock

SESSION_DRIVER=file
SESSION_LIFETIME=120

CACHE_STORE=file
# Для ответов ИИ в Telegram нужен database + cron `schedule:run` (см. DEPLOY.md). sync блокирует вебхук на время запроса к API.
QUEUE_CONNECTION=database

# Почта SMTP (Яндекс: пароль приложения в Яндекс ID → Безопасность)
# MAIL_MAILER=smtp
# MAIL_HOST=smtp.yandex.ru
# MAIL_PORT=465
# MAIL_USERNAME=your@yandex.ru
# MAIL_PASSWORD=
# MAIL_ENCRYPTION=ssl
# MAIL_FROM_ADDRESS="${MAIL_USERNAME}"
# MAIL_FROM_NAME="${APP_NAME}"

# Видеоконференции (Jitsi Meet). По умолчанию — публичный сервер.
# Свой сервер: https://meet.ваш-домен.ru (без слэша в конце)
JITSI_SERVER_URL=https://meet.jit.si

# Push-уведомления PWA (сгенерировать: php artisan pwa:vapid)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
